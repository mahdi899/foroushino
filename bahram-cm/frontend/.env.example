# ----------------------------------------------------------------------------
# Academy Web — frontend environment variables
# Copy to `.env.local` for development. All NEXT_PUBLIC_* vars are exposed to
# the browser, so never put secrets here.
# ----------------------------------------------------------------------------

# --- Backend API (proxied through Next.js in dev; same origin as the site) ---
# Server-only: internal Laravel URL used by middleware to proxy /admin and /api.
BACKEND_PROXY_URL=http://127.0.0.1:8010
# Public API base — browser calls http://localhost:3000/api/...
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Direct Laravel origin for resized images (/cdn/...) — skips Next.js proxy hop.
# Dev: point at the Laravel app (same host as BACKEND_PROXY_URL).
NEXT_PUBLIC_CDN_ORIGIN=http://127.0.0.1:8010

# Disable static cache + image optimization (serve raw /media files, no ISR/CDN resize).
NEXT_PUBLIC_DISABLE_CACHE=1
NEXT_PUBLIC_DISABLE_IMAGE_OPTIMIZATION=1

# Secret shared with Laravel for ISR webhook (/api/revalidate) — generate a long random string.
REVALIDATE_SECRET=change-me-in-production

# --- Canonical site URL (used for SEO metadata, sitemap, OG) ---
# Production example: https://bahramrostami.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Analytics: Plausible (default, privacy-friendly) ---
# Set the domain you registered in Plausible to enable tracking.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Override only if self-hosting Plausible.
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# --- Analytics: Google Analytics 4 (optional) ---
# Provide a measurement ID (G-XXXXXXX) to additionally enable GA4.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- CMS: Sanity (optional; falls back to local MDX when unset) ---
# When configured, the content layer can read from Sanity instead of /content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Server-only read token (leave empty for public datasets).
SANITY_READ_TOKEN=
