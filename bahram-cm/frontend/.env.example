# ----------------------------------------------------------------------------
# Academy Web — frontend environment variables
# Copy to `.env.local` for development. All NEXT_PUBLIC_* vars are exposed to
# the browser, so never put secrets here.
# ----------------------------------------------------------------------------

# --- Backend API (proxied through Next.js in dev; same origin as the site) ---
# Server-only: internal Laravel URL used by middleware to proxy /admin and /api.
BACKEND_PROXY_URL=http://127.0.0.1:8010
# Public API base — browser calls http://localhost:3000/api/...
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Optional: set to 1 to bypass Next.js image optimizer (loads full originals — slower).
# NEXT_PUBLIC_DISABLE_IMAGE_OPTIMIZATION=1

# Direct Laravel origin for media when served from a separate host (optional in dev).
NEXT_PUBLIC_CDN_ORIGIN=http://127.0.0.1:8010

# Secret shared with Laravel for ISR webhook (/api/revalidate) — generate a long random string.
REVALIDATE_SECRET=change-me-in-production

# --- Error tracking (optional) ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# --- Canonical site URL (used for SEO metadata, sitemap, OG) ---
# Production (rostami.app): https://rostami.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Option B dual-domain: rostami.app (main site) + rostami.club (Family PWA) ---
# Both hosts run this SAME Next.js process; middleware.ts uses these two vars
# to decide when to rewrite `/` → `/family` (on the club apex) and when to
# redirect `/family` or `/panel` across domains with an SSO handoff. Leave
# BOTH empty for local dev / single-domain deployments (no-op, `/family`
# just works as a normal path on one origin).
# NEXT_PUBLIC_APP_DOMAIN=rostami.app
# NEXT_PUBLIC_FAMILY_DOMAIN=rostami.club

# --- Family realtime (Laravel Reverb) — optional; leave key empty to use HTTP polling only ---
# Must match backend REVERB_* when BROADCAST_CONNECTION=reverb
# Start server: cd backend && php artisan reverb:start
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# --- Google reCAPTCHA v3 (invisible) — فرم‌ها و چت‌بات ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Server-only (backend .env): RECAPTCHA_SECRET_KEY

# --- Production rostami.app + rostami.club (Arvan CDN, Option B dual-domain) ---
# Copy to server .env.local. Next.js only ever binds one port (:3000); both
# public hostnames are routed to it by nginx (see deploy/nginx/rostami-*.conf).
# NEXT_PUBLIC_SITE_URL=https://rostami.app
# NEXT_PUBLIC_API_BASE_URL=https://rostami.app
# BACKEND_PROXY_URL=http://127.0.0.1:8010
# NEXT_PUBLIC_CDN_ORIGIN=https://cdn.rostami.app
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=<site-key>
# NEXT_PUBLIC_APP_DOMAIN=rostami.app
# NEXT_PUBLIC_FAMILY_DOMAIN=rostami.club

# --- Analytics: Plausible (default, privacy-friendly) ---
# Set the domain you registered in Plausible to enable tracking.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Override only if self-hosting Plausible.
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# --- Analytics: Google Analytics 4 (optional) ---
# Provide a measurement ID (G-XXXXXXX) to additionally enable GA4.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- CMS: Sanity (optional; falls back to local MDX when unset) ---
# When configured, the content layer can read from Sanity instead of /content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Server-only read token (leave empty for public datasets).
SANITY_READ_TOKEN=
