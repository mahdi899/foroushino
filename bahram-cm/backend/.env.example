APP_NAME="Bahram"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bahram_backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Dev-only OTP bypass (local only — never enable in production)
OTP_DEV_MODE=true
OTP_DEV_CODE=12345

# Dev-only payment bypass (local only — skips Zarinpal and auto-completes checkout)
PAYMENT_DEV_MODE=true

# ISR webhook — must match Next.js REVALIDATE_SECRET
FRONTEND_URL=http://localhost:3000
REVALIDATE_SECRET=bahram-dev-revalidate-secret
REVALIDATE_WEBHOOK_URL=http://localhost:3000/api/revalidate

# Public CDN origin for uploaded media (production: https://cdn.example.com)
# When set, absolute media URLs in API responses use this host.
MEDIA_URL=
ASSET_URL=
MEDIA_CACHE_MAX_AGE=31536000

# Cloudflare — optional; can also be set in admin → Settings → Cache integrations
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
