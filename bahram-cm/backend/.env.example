# ============================================================================
# Bahram CM — Backend Environment
# Copy to .env and configure per environment.
# ============================================================================

# ----------------------------------------------------------------------------
# DEVELOPMENT (defaults below — safe for local)
# ----------------------------------------------------------------------------
APP_NAME="Bahram"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8010
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bahram_backend
DB_USERNAME=root
DB_PASSWORD=

# Optional explicit paths for database backup/restore (Windows/Linux)
# MYSQLDUMP_PATH=
# MYSQL_PATH=

# Dev: database sessions OK. Production: use redis (see PRODUCTION section).
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=false
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Distinct per-app namespace so bahram-cm and saat never collide on the same Redis host.
REDIS_PREFIX=bahram_database_
REDIS_PERSISTENT=true
REDIS_READ_WRITE_TIMEOUT=60

# Dev-only OTP bypass (never enable in production)
OTP_DEV_MODE=true
OTP_DEV_CODE=12345
# OTP_SKIP_ADMIN=true   ← skip SMS OTP step for admin/sat panel login (local only)

# ISR webhook — must match Next.js REVALIDATE_SECRET
REVALIDATE_SECRET=bahram-dev-revalidate-secret-change-me
REVALIDATE_WEBHOOK_URL=http://localhost:3000/api/revalidate

# Internal server-to-server API (chatbot gates, captcha) — separate from REVALIDATE
INTERNAL_API_SECRET=bahram-dev-internal-secret-change-me

# Identity PII — generate: php -r "echo bin2hex(random_bytes(32));"
IDENTITY_NATIONAL_CODE_HMAC_KEY=

# Sanctum — comma-separated domains for SPA cookie auth (production only)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

# ----------------------------------------------------------------------------
# Broadcasting / Laravel Reverb (Family realtime — badge + feed)
# Default null = HTTP polling only; app works without `php artisan reverb:start`.
# Local enable:
#   BROADCAST_CONNECTION=reverb
#   php artisan reverb:start
# Match NEXT_PUBLIC_REVERB_* in frontend/.env.local
# ----------------------------------------------------------------------------
BROADCAST_CONNECTION=null
REVERB_APP_ID=bahram
REVERB_APP_KEY=bahram-reverb-key
REVERB_APP_SECRET=bahram-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Trusted reverse proxies (Nginx on same host). Cloudflare → Nginx on same machine.
# Include Next.js when it proxies/server-actions to Laravel so X-Forwarded-For is honored.
TRUSTED_PROXIES=127.0.0.1

# Global API throttle (requests/min/IP). Local default is high — family feed
# server actions share one loopback IP and would otherwise trip login.
# API_RATE_LIMIT_PER_MINUTE=120
# STUDENT_AUTH_RATE_LIMIT_PER_MINUTE=30

# Public CDN origin for uploaded media (Cloudflare: cdn.rostami.app)
# Local dev: leave unset to auto-use ARVAN_MEDIA_DOMAIN (cdn.rostami.app).
MEDIA_URL=
ASSET_URL=
MEDIA_CACHE_MAX_AGE=31536000

# Captcha: Cloudflare Turnstile (اولویت ۱) + Google reCAPTCHA v3 (اولویت ۲)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_THRESHOLD=0.5

# CDN edge: cloudflare | arvan | none (قابل تغییر از پنل ادمین)
CDN_PROVIDER=cloudflare

# Cloudflare CDN purge + dev mode toggle
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Arvan Cloud CDN purge (اختیاری — اگر CDN_PROVIDER=arvan)
ARVAN_API_KEY=
ARVAN_DOMAIN=rostami.app
ARVAN_MEDIA_DOMAIN=cdn.rostami.app

# ----------------------------------------------------------------------------
# Family — "خانواده داداش بهرام" (FTP download host + CDN, never S3, never
# through the main Laravel server for playback). See docs/FAMILY.md
#
# Option B (true dual-domain): Family PWA lives on its OWN apex domain
# rostami.club, separate from the main site rostami.app. FAMILY_ENTRY_BASE_URL
# must point at the club domain (not FRONTEND_URL) so entry links, Telegram
# deep-links, and the family manifest/SW all resolve to the correct origin.
# ----------------------------------------------------------------------------
FAMILY_CAPACITY_TARGET=5000
FAMILY_CAPACITY_MIN=4500
FAMILY_CAPACITY_MAX=5200
FAMILY_ASSIGNMENT_LOCK_SECONDS=10
FAMILY_ENTRY_BASE_URL=https://rostami.club
FAMILY_ENTRY_PATH=
# Local dev (single Next.js origin, path-based family): FAMILY_ENTRY_BASE_URL=http://localhost:3000 FAMILY_ENTRY_PATH=family

# FTP download host — write-only from Laravel/workers; never reachable by browsers.
FAMILY_MEDIA_FTP_HOST=
FAMILY_MEDIA_FTP_PORT=21
FAMILY_MEDIA_FTP_USERNAME=
FAMILY_MEDIA_FTP_PASSWORD=
FAMILY_MEDIA_FTP_ROOT=/
FAMILY_MEDIA_FTP_PASSIVE=true
FAMILY_MEDIA_FTP_SSL=false
FAMILY_MEDIA_FTP_TIMEOUT=60

# CDN that pulls from the FTP host — this is the ONLY URL ever sent to clients.
FAMILY_MEDIA_CDN_URL=https://family-cdn.rostami.club

# Local dev: public disk — files land in storage/app/public/media/family/ and appear in the media library.
# Production: family_media_ftp (same path layout under FTP root for CDN pull).
FAMILY_MEDIA_DISK=public
# FAMILY_MEDIA_CDN_URL=   ← leave empty locally; URLs use /storage/media/family/…
FAMILY_OPTIMIZE_IMAGES=true
FAMILY_SYNC_TO_SITE_MEDIA=true
FAMILY_FTP_UPLOAD_ENABLED=true
# Site media library FTP (production): MEDIA_DISK=site_media_ftp
# NOTE: Host/Username/Password/Port/Protocol below can ALSO be set from the
# admin panel (Media > Download host) — panel values, if saved, take
# precedence over these env vars for site_media_ftp/site_media_sftp at
# runtime (see App\Support\MediaFtpConnection). Keep both in sync in prod.
MEDIA_FTP_HOST=
MEDIA_FTP_USERNAME=
MEDIA_FTP_PASSWORD=
MEDIA_FTP_ROOT=/
# SFTP counterpart — set MEDIA_DISK=site_media_sftp to use this instead of plain FTP
MEDIA_SFTP_HOST=
MEDIA_SFTP_USERNAME=
MEDIA_SFTP_PASSWORD=
MEDIA_SFTP_PRIVATE_KEY=
MEDIA_SFTP_PASSPHRASE=
MEDIA_SFTP_PORT=22
MEDIA_SFTP_ROOT=/

# Off-site weekly backups on download host (FTP/CDN) — backups/{bahram|saat}/{random}/
# Bahram uses panel FTP (Media > Download host) when enabled; env below is fallback.
BACKUP_FTP_BASE=backups
BACKUP_SITE_SLUG=bahram
BACKUP_CDN_URL=https://cdn.rostami.app
BACKUP_FTP_RETENTION_DAYS=90
BACKUP_WEEKLY_WEEKDAY=0
BACKUP_FTP_HOST=
BACKUP_FTP_USERNAME=
BACKUP_FTP_PASSWORD=
BACKUP_FTP_ROOT=/

FAMILY_MEDIA_TEMP_DISK=local
FAMILY_MEDIA_MAX_VOICE_MB=50
FAMILY_MEDIA_MAX_VIDEO_MB=500
FAMILY_MEDIA_MAX_IMAGE_MB=15
FAMILY_MEDIA_CHUNK_SIZE_MB=5

FAMILY_RATE_COMMENT=5
FAMILY_RATE_REACTION=30
FAMILY_RATE_ACTION=10
FAMILY_RATE_PROGRESS=60
FAMILY_RATE_UPLOAD=40

# ----------------------------------------------------------------------------
# Security — proxy-origin gate + server-to-server HMAC signing
#
# PROXY_SHARED_TOKEN is the Bearer secret the Cloudflare Worker injects when
# forwarding the Telegram webhook (strict mode — must match exactly). The
# same header (X-Proxy-Origin) is also required, in "presence" mode, on the
# SAT integration routes; there the Bearer token is the per-installation
# SAT integration token instead of this shared secret.
#
# SAT_SYNC_HMAC_SECRET must be IDENTICAL to the value configured on the Saat
# backend (saat/backend .env → SAT_SYNC_HMAC_SECRET) — it signs/verifies the
# Bahram → Saat "applications" push. BAHRAM_CALLBACK_HMAC_SECRET on Saat's
# side signs the reverse "lead status" callback into the endpoint below.
# ----------------------------------------------------------------------------
PROXY_ORIGIN_HEADER=X-Proxy-Origin
PROXY_ORIGIN_ALLOWED_VALUES=Cloudflare-Worker,Internal-Sync
PROXY_SHARED_TOKEN=

SAT_SYNC_HMAC_SECRET=
SAT_SYNC_HMAC_MAX_SKEW_SECONDS=300
SAT_SYNC_HMAC_NONCE_TTL_SECONDS=600

# ----------------------------------------------------------------------------
# Telegram Bot — @RostamiAppBot (shared across the whole ecosystem: this
# academy bot AND the Saat Mini App "satcenter" verify initData with the SAME
# token). This app (bahram-cm) OWNS the webhook — Saat only verifies tokens,
# it never registers its own webhook.
#
# Production webhook path: Telegram → Cloudflare Worker (worker/) → this
# server. The Worker is the ONLY public endpoint registered with Telegram
# (via `telegram:webhook:set`, which reads TELEGRAM_WEBHOOK_BASE_URL below);
# it verifies X-Telegram-Bot-Api-Secret-Token itself, then forwards to
# rostami.app injecting `Authorization: Bearer <PROXY_SHARED_TOKEN>` +
# `X-Proxy-Origin: Cloudflare-Worker`. Direct requests to rostami.app that
# skip the Worker are dropped by `proxy.origin:strict` before the Telegram
# secret is even checked (see routes/telegram.php). This also sidesteps
# ISP-level filtering/blocking of rostami.app inside Iran for the webhook
# call itself, since Telegram now talks to Cloudflare's edge, not to Iran.
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=RostamiAppBot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_KEY=production
# Local/no-worker dev: point straight at APP_URL. Production: the Cloudflare
# Worker's public URL, e.g. https://bahram-telegram-bridge.<you>.workers.dev
# Panel override: /admin/telegram/settings → «پل Cloudflare Worker»
TELEGRAM_WEBHOOK_BASE_URL=https://rostami.app
# Outbound Bot API — https://api.telegram.org or the same Worker URL (Iran):
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_SITE_BASE_URL=https://rostami.app
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_HTTP_TIMEOUT=20
TELEGRAM_HTTP_CONNECT_TIMEOUT=5
TELEGRAM_MINIAPP_MAX_AUTH_AGE=86400
TELEGRAM_PERMANENT_ADMIN_USER_IDS=97343715,303360676
TELEGRAM_PERMANENT_ADMIN_USERNAMES=PVamin,mahdi_akbari

# Sat Center Mini App (t.me/RostamiAppBot/satcenter) — same bot, hosted at sat.center.
TELEGRAM_SATCENTER_MINIAPP_URL=https://sat.center/

# ----------------------------------------------------------------------------
# PRODUCTION — rostami.app + rostami.club (Option B: true dual-domain)
# Both hosts are served by the SAME Next.js process + SAME Laravel backend;
# only the public hostname differs. Cloudflare CDN fronts rostami.app.
# ----------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=http://127.0.0.1:8010
# FRONTEND_URL=https://rostami.app
# CORS_ALLOWED_ORIGINS=https://rostami.app,https://rostami.club
# LOG_CHANNEL=daily
# LOG_LEVEL=warning
# SESSION_DRIVER=redis
# SESSION_SECURE_COOKIE=true
# OTP_DEV_MODE=false
# REVALIDATE_SECRET=<64-char-random>
# INTERNAL_API_SECRET=<64-char-random-different-from-revalidate>
# IDENTITY_NATIONAL_CODE_HMAC_KEY=<64-char-random>
# SANCTUM_STATEFUL_DOMAINS=rostami.app,rostami.club
# PROXY_SHARED_TOKEN=<64-char-random, shared with worker/wrangler secret PROXY_SHARED_TOKEN>
# SAT_SYNC_HMAC_SECRET=<64-char-random, IDENTICAL to saat/backend .env SAT_SYNC_HMAC_SECRET>
# MEDIA_URL=https://cdn.rostami.app
# CDN_PROVIDER=cloudflare
# CLOUDFLARE_ZONE_ID=<zone-id>
# CLOUDFLARE_API_TOKEN=<api-token>
# FAMILY_ENTRY_BASE_URL=https://rostami.club
# FAMILY_ENTRY_PATH=
# FAMILY_MEDIA_CDN_URL=https://family-cdn.rostami.club
# RECAPTCHA_SITE_KEY=<from-google-admin>
# RECAPTCHA_SECRET_KEY=<from-google-admin>
#
# Default admin account is seeded with a placeholder password — change it via
# `php artisan tinker` or the admin panel immediately after first deploy, and
# rotate TELEGRAM_BOT_TOKEN if it is ever committed to a public repo.
