# --- Application ---
APP_ENV=development
APP_NAME=Bahram CM API
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# --- Security ---
SECRET_KEY=change-me-please-32-characters-min-32

# --- Database (MySQL 8) ---
DATABASE_URL=mysql+aiomysql://bahram:bahram@localhost:3306/bahram_cm
DATABASE_URL_SYNC=mysql+pymysql://bahram:bahram@localhost:3306/bahram_cm

# --- Redis (rate limiting for public forms) ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX="https?://(localhost|127\.0\.0\.1)(:\d+)?$"
