# Bahram CM — log rotation
# Copy to /etc/logrotate.d/bahram

/var/www/bahram-cm/backend/storage/logs/*.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 0640 www-data www-data
    sharedscripts
    postrotate
        # Reload PHP-FPM if slow log rotated
        systemctl reload php8.2-fpm > /dev/null 2>&1 || true
    endscript
}

/var/log/nginx/*.log {
    daily
    missingok
    rotate 14
    compress
    delaycompress
    notifempty
    sharedscripts
    postrotate
        systemctl reload nginx > /dev/null 2>&1 || true
    endscript
}

/var/log/supervisor/bahram-queue.log {
    weekly
    missingok
    rotate 8
    compress
    notifempty
}

/var/log/pm2/bahram-frontend-*.log {
    weekly
    missingok
    rotate 8
    compress
    notifempty
}
