# Bahram + Family production server
# Copy to deploy.env and fill in — deploy.env is gitignored. Never commit real hosts/passwords.
DEPLOY_HOST=YOUR_SERVER_IP_OR_HOSTNAME
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_PASSWORD=

# Paths on server (defaults match bootstrap-server.sh)
# DEPLOY_APP_ROOT — canonical app path (symlink → $DEPLOY_GIT_ROOT/bahram-cm).
# Use this for uploads AND remote shell commands in all deploy scripts.
DEPLOY_APP_ROOT=/var/www/bahram-cm
# DEPLOY_GIT_ROOT — git clone root only (git pull runs here)
DEPLOY_GIT_ROOT=/var/www/foroushino
