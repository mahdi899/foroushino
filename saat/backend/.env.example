APP_NAME=Saat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Production: APP_URL=https://satcall.ir
APP_TIMEZONE=Asia/Tehran
APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saat
DB_USERNAME=root
DB_PASSWORD=

DB_TIMEZONE=+03:30

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: SESSION_DOMAIN=.satcall.ir

# Use "null" unless Reverb is running (php artisan reverb:start). A dead broadcaster breaks call-result saves.
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@saat.local"
# Production: MAIL_FROM_ADDRESS="noreply@satcall.ir"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=saat
REVERB_APP_KEY=saat-reverb-key
REVERB_APP_SECRET=saat-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
# Production (if using Reverb): REVERB_HOST=satcall.ir REVERB_PORT=443 REVERB_SCHEME=https

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
# Production: SANCTUM_STATEFUL_DOMAINS=satcall.ir,www.satcall.ir

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_AUTH_MAX_AGE=86400
DEV_LOGIN_ENABLED=true
# Production: DEV_LOGIN_ENABLED=false

# Fixed OTP demo accounts (local only — never enable in production)
DEMO_OTP_ENABLED=true
# Production: DEMO_OTP_ENABLED=false

MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_REST_URL=https://rest.payamak-panel.com/api/SendSMS
