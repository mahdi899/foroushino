APP_NAME=Saat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Production: APP_URL=https://sat.center
APP_TIMEZONE=Asia/Tehran
APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saat
DB_USERNAME=root
DB_PASSWORD=

DB_TIMEZONE=+03:30

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: SESSION_DOMAIN=.sat.center

# Use "null" unless Reverb is running (php artisan reverb:start). A dead broadcaster breaks call-result saves.
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Distinct per-app namespace — must differ from bahram-cm's REDIS_PREFIX
# whenever both apps share the same Redis host.
REDIS_PREFIX=saat_database_
REDIS_PERSISTENT=true
REDIS_READ_WRITE_TIMEOUT=60

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@saat.local"
# Production: MAIL_FROM_ADDRESS="noreply@sat.center"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=saat
REVERB_APP_KEY=saat-reverb-key
REVERB_APP_SECRET=saat-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
# Production (if using Reverb): REVERB_HOST=sat.center REVERB_PORT=443 REVERB_SCHEME=https

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
# Production: SANCTUM_STATEFUL_DOMAINS=sat.center,www.sat.center

# Shared bot @RostamiAppBot (t.me/RostamiAppBot) — same token as bahram-cm's
# TelegramBot module. Saat only verifies Mini App initData signatures with
# this token; it does NOT register its own webhook (bahram-cm owns that, on
# rostami.app). Mini App short name: "satcenter" → t.me/RostamiAppBot/satcenter
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=RostamiAppBot
TELEGRAM_AUTH_MAX_AGE=86400
DEV_LOGIN_ENABLED=true
# Production: DEV_LOGIN_ENABLED=false

# Fixed OTP demo accounts (local only — never enable in production)
DEMO_OTP_ENABLED=true
# Production: DEMO_OTP_ENABLED=false

MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_REST_URL=https://rest.payamak-panel.com/api/SendSMS

# ----------------------------------------------------------------------------
# Security — proxy-origin gate + server-to-server HMAC signing (REST sync
# with Bahram / Server 1, https://rostami.app). Saat has no public webhook of
# its own — these only protect /api/v1/integrations/inbound/* and the
# outbound callback below.
#
# PROXY_ORIGIN_ALLOWED_VALUES must match bahram-cm's config; Bahram sends
# "Internal-Sync" as the value of X-Proxy-Origin on every outbound call.
#
# SAT_SYNC_HMAC_SECRET must be IDENTICAL to bahram-cm's .env value of the
# same name — it verifies the inbound "applications" push from Bahram.
# ----------------------------------------------------------------------------
PROXY_ORIGIN_HEADER=X-Proxy-Origin
PROXY_ORIGIN_ALLOWED_VALUES=Cloudflare-Worker,Internal-Sync
PROXY_SHARED_TOKEN=

SAT_SYNC_HMAC_SECRET=
SAT_SYNC_HMAC_MAX_SKEW_SECONDS=300
SAT_SYNC_HMAC_NONCE_TTL_SECONDS=600

# Reverse channel — Saat -> Bahram lead-status callback. BAHRAM_CALLBACK_URL
# points at Bahram's /api/v1/integrations/inbound/sat-status endpoint;
# BAHRAM_CALLBACK_TOKEN is a SatIntegrationToken issued by Bahram with the
# `callback:lead-status` ability. BAHRAM_CALLBACK_HMAC_SECRET may reuse
# SAT_SYNC_HMAC_SECRET (default) or be set independently.
BAHRAM_CALLBACK_URL=https://rostami.app/api/v1/integrations/inbound/sat-status
BAHRAM_CALLBACK_TOKEN=
BAHRAM_CALLBACK_HMAC_SECRET=

# Weekly off-site backups on download host — backups/saat/{random}/
BACKUP_FTP_BASE=backups
BACKUP_SITE_SLUG=saat
BACKUP_CDN_URL=
BACKUP_FTP_RETENTION_DAYS=90
BACKUP_WEEKLY_WEEKDAY=0
BACKUP_FTP_HOST=
BACKUP_FTP_USERNAME=
BACKUP_FTP_PASSWORD=
BACKUP_FTP_ROOT=/

# ----------------------------------------------------------------------------
# PRODUCTION overrides — sat.center
# ----------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://sat.center
# LOG_CHANNEL=daily
# LOG_LEVEL=warning
# SESSION_DRIVER=redis
# SESSION_DOMAIN=.sat.center
# DEV_LOGIN_ENABLED=false
# DEMO_OTP_ENABLED=false
# PROXY_SHARED_TOKEN=<64-char-random>
# SAT_SYNC_HMAC_SECRET=<64-char-random, IDENTICAL to bahram-cm .env SAT_SYNC_HMAC_SECRET>
