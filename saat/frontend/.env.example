# Data layer switch (see src/services/index.ts). Defaults to "mock" when unset.
VITE_API_MODE=http

# Production (sat.center): leave VITE_API_BASE_URL empty so the SPA uses same-origin /api/v1
# (Nginx proxies /api → Laravel). For local absolute API:
# VITE_API_BASE_URL=http://localhost:8000/api/v1

# Update banner mode for this build: optional | forced | silent
# VITE_UPDATE_TYPE=optional

# Shared bot @RostamiAppBot — Mini App short name "satcenter" (t.me/RostamiAppBot/satcenter)
# VITE_TELEGRAM_BOT_USERNAME=RostamiAppBot
