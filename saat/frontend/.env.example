# Data layer switch (see src/services/index.ts). Defaults to "mock" when unset.
VITE_API_MODE=http
# For phone/PWA testing use your PC LAN IP — not localhost.
VITE_API_BASE_URL=http://192.168.6.134:8000/api/v1
# VITE_TELEGRAM_BOT_USERNAME=YourBotUsername

# Demo OTP is controlled by backend DEMO_OTP_ENABLED (not frontend).
# To test real Telegram OTP: set DEMO_OTP_ENABLED=false in backend .env
# Enable in-app VoIP dialer (default: off — native SIM dialer only)
# VITE_VOIP_CALL_ENABLED=true
